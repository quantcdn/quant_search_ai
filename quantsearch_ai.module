<?php

/**
 * @file
 * Primary module hooks for QuantSearch AI module.
 */

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\node\NodeInterface;

/**
 * Implements hook_help().
 */
function quantsearch_ai_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.quantsearch_ai':
      $output = '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('The QuantSearch AI module integrates Drupal with <a href="@url">QuantSearch.ai</a> for AI-powered semantic search and chat widgets.', [
        '@url' => 'https://quantsearch.ai',
      ]) . '</p>';
      $output .= '<h3>' . t('Features') . '</h3>';
      $output .= '<ul>';
      $output .= '<li>' . t('Semantic search powered by AI embeddings') . '</li>';
      $output .= '<li>' . t('AI chatbot widget for conversational search') . '</li>';
      $output .= '<li>' . t('Real-time content indexing on node save') . '</li>';
      $output .= '<li>' . t('Bulk indexing via Drush commands') . '</li>';
      $output .= '</ul>';
      return $output;
  }
}

/**
 * Implements hook_node_insert().
 */
function quantsearch_ai_node_insert(NodeInterface $node) {
  _quantsearch_ai_index_node($node, 'insert');
}

/**
 * Implements hook_node_update().
 */
function quantsearch_ai_node_update(NodeInterface $node) {
  // If node was unpublished, delete from index. On multilingual sites we must
  // only delete the affected translation — the legacy delete path fans out
  // across every translation, which would drop still-published translations
  // from their language-specific sites.
  if (!$node->isPublished() && isset($node->original) && $node->original->isPublished()) {
    /** @var \Drupal\quantsearch_ai\Service\SiteResolver $resolver */
    $resolver = \Drupal::service('quantsearch_ai.site_resolver');
    if ($resolver->isMultilingual()) {
      if (!_quantsearch_ai_is_configured()) {
        return;
      }
      /** @var \Drupal\quantsearch_ai\Service\IndexingService $indexing */
      $indexing = \Drupal::service('quantsearch_ai.indexing');
      $langcode = $node->language()->getId();
      try {
        $indexing->deleteNodeLanguage($node, $langcode);
      }
      catch (\Exception $e) {
        \Drupal::logger('quantsearch_ai')->error('Failed to delete unpublished node @nid lang=@lang: @msg', [
          '@nid' => $node->id(),
          '@lang' => $langcode,
          '@msg' => $e->getMessage(),
        ]);
      }
    }
    else {
      _quantsearch_ai_delete_node($node);
    }
  }
  else {
    _quantsearch_ai_index_node($node, 'update');
  }
}

/**
 * Implements hook_node_delete().
 */
function quantsearch_ai_node_delete(NodeInterface $node) {
  _quantsearch_ai_delete_node($node);
}

/**
 * Implements hook_entity_translation_insert().
 *
 * Fires when a translation is added to an existing translatable entity.
 * The default translation is handled by hook_node_insert/update; we only
 * act on additional language translations here so we can push just the
 * changed language rather than re-indexing every translation.
 */
function quantsearch_ai_entity_translation_insert(EntityInterface $translation) {
  if (!$translation instanceof NodeInterface) {
    return;
  }
  _quantsearch_ai_index_translation($translation, 'insert');
}

// NOTE: hook_entity_translation_update is intentionally NOT implemented.
// Drupal 11 core's ContentEntityStorageBase::invokeTranslationHooks() only
// fires translation_insert and translation_delete — never translation_update.
// Translation edits are handled by hook_node_update() with $node set to the
// saved translation entity (its language() returns the language being edited).

/**
 * Implements hook_entity_translation_delete().
 *
 * Fires when a translation is removed from a translatable entity.
 */
function quantsearch_ai_entity_translation_delete(EntityInterface $translation) {
  if (!$translation instanceof NodeInterface) {
    return;
  }
  // Default translation removal is handled by hook_node_delete.
  if ($translation->isDefaultTranslation()) {
    return;
  }

  if (!_quantsearch_ai_is_configured()) {
    return;
  }

  /** @var \Drupal\quantsearch_ai\Service\IndexingService $indexing */
  $indexing = \Drupal::service('quantsearch_ai.indexing');
  $langcode = $translation->language()->getId();
  try {
    $indexing->deleteNodeLanguage($translation, $langcode);
  }
  catch (\Exception $e) {
    \Drupal::logger('quantsearch_ai')->error('Failed to delete translation @nid:@lang: @msg', [
      '@nid' => $translation->id(),
      '@lang' => $langcode,
      '@msg' => $e->getMessage(),
    ]);
  }
}

/**
 * Index a single translation of a node to QuantSearch.
 *
 * @param \Drupal\node\NodeInterface $translation
 *   The translation entity (already in the target language).
 * @param string $operation
 *   The operation type (insert, update).
 */
function _quantsearch_ai_index_translation(NodeInterface $translation, string $operation) {
  // Default translation is handled by hook_node_insert/update which fans out
  // across all translations via IndexingService::indexNode(). Skipping here
  // prevents double-indexing on initial node creation.
  if ($translation->isDefaultTranslation()) {
    return;
  }

  $config = \Drupal::config('quantsearch_ai.settings');
  if (!$config->get('indexing.enabled')) {
    return;
  }
  $content_types = $config->get('indexing.content_types') ?: [];
  if (empty($content_types) || !in_array($translation->bundle(), $content_types)) {
    return;
  }
  if ($config->get('indexing.exclude_unpublished') && !$translation->isPublished()) {
    return;
  }
  if (!_quantsearch_ai_is_configured()) {
    return;
  }

  /** @var \Drupal\quantsearch_ai\Service\IndexingService $indexing */
  $indexing = \Drupal::service('quantsearch_ai.indexing');
  $langcode = $translation->language()->getId();

  if ($config->get('indexing.realtime')) {
    try {
      $indexing->indexNodeLanguage($translation, $langcode);
    }
    catch (\Exception $e) {
      \Drupal::logger('quantsearch_ai')->error('Failed to index translation @nid:@lang: @msg', [
        '@nid' => $translation->id(),
        '@lang' => $langcode,
        '@msg' => $e->getMessage(),
      ]);
    }
  }
  else {
    /** @var \Drupal\Core\Queue\QueueFactory $queueFactory */
    $queueFactory = \Drupal::service('queue');
    $queueFactory->get('quantsearch_content_index')->createItem([
      'nid' => $translation->id(),
      'langcode' => $langcode,
      'operation' => 'index',
    ]);
  }
}

/**
 * Index a node to QuantSearch.
 *
 * @param \Drupal\node\NodeInterface $node
 *   The node to index.
 * @param string $operation
 *   The operation type (insert, update).
 */
function _quantsearch_ai_index_node(NodeInterface $node, string $operation) {
  $config = \Drupal::config('quantsearch_ai.settings');

  // Check if indexing is enabled
  if (!$config->get('indexing.enabled')) {
    return;
  }

  // Check if this content type should be indexed
  $content_types = $config->get('indexing.content_types') ?: [];
  if (empty($content_types) || !in_array($node->bundle(), $content_types)) {
    return;
  }

  // Check if unpublished should be excluded
  if ($config->get('indexing.exclude_unpublished') && !$node->isPublished()) {
    return;
  }

  // Check if we have a valid connection
  if (!_quantsearch_ai_is_configured()) {
    return;
  }

  /** @var \Drupal\quantsearch_ai\Service\IndexingService $indexing */
  $indexing = \Drupal::service('quantsearch_ai.indexing');
  /** @var \Drupal\quantsearch_ai\Service\SiteResolver $resolver */
  $resolver = \Drupal::service('quantsearch_ai.site_resolver');

  // Real-time or queued indexing
  if ($config->get('indexing.realtime')) {
    try {
      if ($resolver->isMultilingual()) {
        if ($operation === 'insert') {
          // Brand new node: index every translation. hook_entity_translation_insert
          // does not fire for translations created alongside the parent in a single
          // save, so we have to fan out here.
          $indexing->indexNode($node);
        }
        else {
          // Update: index whichever language was saved. $node->language()->getId()
          // is the language of the entity passed to hook_node_update (which is the
          // translation that was saved). hook_entity_translation_update may also
          // fire for non-default translations on this same save; the resulting
          // duplicate ingest is idempotent at the backend (same key+content).
          $indexing->indexNodeLanguage($node, $node->language()->getId());
        }
      }
      else {
        $indexing->indexNode($node);
      }
    }
    catch (\Exception $e) {
      \Drupal::logger('quantsearch_ai')->error('Failed to index node @nid: @message', [
        '@nid' => $node->id(),
        '@message' => $e->getMessage(),
      ]);
    }
  }
  else {
    // Queue for batch processing.
    if ($resolver->isMultilingual() && $operation !== 'insert') {
      // Update: enqueue only the saved language.
      $queueFactory = \Drupal::service('queue');
      $queueFactory->get('quantsearch_content_index')->createItem([
        'nid' => $node->id(),
        'langcode' => $node->language()->getId(),
        'operation' => 'index',
      ]);
    }
    else {
      // Brand new multilingual node, or single-language site: queueNode handles both.
      $indexing->queueNode($node);
    }
  }
}

/**
 * Delete a node from QuantSearch index.
 *
 * @param \Drupal\node\NodeInterface $node
 *   The node to delete.
 */
function _quantsearch_ai_delete_node(NodeInterface $node) {
  // Check if we have a valid connection
  if (!_quantsearch_ai_is_configured()) {
    return;
  }

  /** @var \Drupal\quantsearch_ai\Service\IndexingService $indexing */
  $indexing = \Drupal::service('quantsearch_ai.indexing');

  try {
    $indexing->deleteNode($node);
  }
  catch (\Exception $e) {
    \Drupal::logger('quantsearch_ai')->error('Failed to delete node @nid from index: @message', [
      '@nid' => $node->id(),
      '@message' => $e->getMessage(),
    ]);
  }
}

/**
 * Returns TRUE when the module has at least one usable QuantSearch target.
 *
 * The module is considered configured when an API key is present AND either
 * a flat `site_id` is set OR a `language_sites` map is populated. This allows
 * fully-migrated multilingual installs (which may never set the flat
 * `site_id`) to keep functioning.
 *
 * @return bool
 *   TRUE when the module has a usable target configuration.
 */
function _quantsearch_ai_is_configured(): bool {
  $config = \Drupal::config('quantsearch_ai.settings');
  if (!$config->get('api_key_id')) {
    return FALSE;
  }
  /** @var \Drupal\quantsearch_ai\Service\SiteResolver $resolver */
  $resolver = \Drupal::service('quantsearch_ai.site_resolver');
  return $resolver->isMultilingual() || !empty($config->get('site_id'));
}

/**
 * Implements hook_page_attachments().
 */
function quantsearch_ai_page_attachments(array &$attachments) {
  $config = \Drupal::config('quantsearch_ai.settings');
  /** @var \Drupal\quantsearch_ai\Service\SiteResolver $resolver */
  $resolver = \Drupal::service('quantsearch_ai.site_resolver');
  $langcode = \Drupal::languageManager()->getCurrentLanguage()->getId();
  $site_id = $resolver->getSiteId($langcode);

  if (!$site_id) {
    return;
  }

  // Attach chat widget settings if enabled globally (script added in hook_page_bottom)
  if ($config->get('widgets.chat.enabled')) {
    $attachments['#attached']['drupalSettings']['quantsearch_ai']['chat_enabled'] = TRUE;
    $attachments['#attached']['drupalSettings']['quantsearch_ai']['site_id'] = $site_id;
  }
  $attachments['#cache']['contexts'][] = 'languages:language_interface';
}

/**
 * Implements hook_page_bottom().
 *
 * Add chat widget script to the bottom of the page where document.body exists.
 */
function quantsearch_ai_page_bottom(array &$page_bottom) {
  $config = \Drupal::config('quantsearch_ai.settings');
  /** @var \Drupal\quantsearch_ai\Service\SiteResolver $resolver */
  $resolver = \Drupal::service('quantsearch_ai.site_resolver');
  $langcode = \Drupal::languageManager()->getCurrentLanguage()->getId();
  $site_id = $resolver->getSiteId($langcode);
  $cdn_url = $config->get('cdn_url') ?: 'https://cdn.quantsearch.ai/v1';

  if (!$site_id) {
    return;
  }

  // Attach chat widget if enabled globally
  if ($config->get('widgets.chat.enabled')) {
    $chat_settings = $config->get('widgets.chat');
    $attributes = [
      'src' => $cdn_url . '/widget.js',
      'data-site-id' => $site_id,
      'data-theme' => $chat_settings['theme'] ?? 'auto',
      'data-position' => $chat_settings['position'] ?? 'bottom-right',
      'data-color' => $chat_settings['color'] ?? '#00d4aa',
      'data-placeholder' => $chat_settings['placeholder'] ?? 'Ask a question...',
      'async' => 'async',
    ];

    if (!empty($chat_settings['greeting'])) {
      $attributes['data-greeting'] = $chat_settings['greeting'];
    }

    $page_bottom['quantsearch_chat_widget'] = [
      '#type' => 'html_tag',
      '#tag' => 'script',
      '#attributes' => $attributes,
      '#cache' => [
        'contexts' => ['languages:language_interface'],
        'tags' => ['config:quantsearch_ai.settings'],
      ],
    ];
  }
}

/**
 * Implements hook_theme().
 */
function quantsearch_ai_theme() {
  return [
    'quantsearch_modal_widget' => [
      'variables' => [
        'site_id' => NULL,
        'cdn_url' => NULL,
        'theme_setting' => 'auto',
        'color' => '#10b981',
        'placeholder' => 'Search...',
        'show_ai_answer' => TRUE,
        'preset_filters' => '',
      ],
      'template' => 'quantsearch-modal-widget',
    ],
    'quantsearch_search_page' => [
      'variables' => [
        'site_id' => NULL,
        'cdn_url' => NULL,
        'theme_setting' => 'auto',
        'color' => '#10b981',
        'show_ai_answer' => TRUE,
        'enable_facets' => FALSE,
        'facet_position' => 'left',
        'preset_filters' => '',
      ],
      'template' => 'quantsearch-search-page',
    ],
  ];
}
